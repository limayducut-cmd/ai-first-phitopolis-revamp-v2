<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 600" width="800" height="600">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#0A2A66"/>
      <stop offset="100%" style="stop-color:#0E2F6E"/>
    </linearGradient>
    <linearGradient id="glow" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#FFC72C;stop-opacity:0.3"/>
      <stop offset="100%" style="stop-color:#A78BFA;stop-opacity:0.1"/>
    </linearGradient>
    <filter id="blur1">
      <feGaussianBlur stdDeviation="40"/>
    </filter>
    <filter id="blur2">
      <feGaussianBlur stdDeviation="25"/>
    </filter>
  </defs>

  <!-- Background -->
  <rect width="800" height="600" fill="url(#bg)"/>

  <!-- Ambient glow blobs -->
  <ellipse cx="200" cy="200" rx="220" ry="180" fill="#FFC72C" opacity="0.08" filter="url(#blur1)"/>
  <ellipse cx="620" cy="400" rx="200" ry="160" fill="#A78BFA" opacity="0.1" filter="url(#blur1)"/>

  <!-- Grid lines -->
  <g stroke="rgba(255,255,255,0.04)" stroke-width="1">
    <line x1="0" y1="100" x2="800" y2="100"/>
    <line x1="0" y1="200" x2="800" y2="200"/>
    <line x1="0" y1="300" x2="800" y2="300"/>
    <line x1="0" y1="400" x2="800" y2="400"/>
    <line x1="0" y1="500" x2="800" y2="500"/>
    <line x1="100" y1="0" x2="100" y2="600"/>
    <line x1="200" y1="0" x2="200" y2="600"/>
    <line x1="300" y1="0" x2="300" y2="600"/>
    <line x1="400" y1="0" x2="400" y2="600"/>
    <line x1="500" y1="0" x2="500" y2="600"/>
    <line x1="600" y1="0" x2="600" y2="600"/>
    <line x1="700" y1="0" x2="700" y2="600"/>
  </g>

  <!-- Central orbit ring -->
  <ellipse cx="400" cy="300" rx="160" ry="160" fill="none" stroke="rgba(255,199,44,0.15)" stroke-width="1"/>
  <ellipse cx="400" cy="300" rx="200" ry="200" fill="none" stroke="rgba(167,139,250,0.1)" stroke-width="1" stroke-dasharray="6 10"/>
  <ellipse cx="400" cy="300" rx="240" ry="240" fill="none" stroke="rgba(255,255,255,0.05)" stroke-width="1"/>

  <!-- Central node -->
  <circle cx="400" cy="300" r="48" fill="rgba(255,199,44,0.08)" stroke="rgba(255,199,44,0.3)" stroke-width="1.5"/>
  <circle cx="400" cy="300" r="28" fill="rgba(255,199,44,0.12)" stroke="rgba(255,199,44,0.5)" stroke-width="1"/>

  <!-- Orbit dots -->
  <circle cx="400" cy="140" r="6" fill="#FFC72C" opacity="0.7"/>
  <circle cx="544" cy="222" r="5" fill="#A78BFA" opacity="0.6"/>
  <circle cx="544" cy="378" r="5" fill="#60A5FA" opacity="0.6"/>
  <circle cx="400" cy="460" r="6" fill="#34D399" opacity="0.6"/>
  <circle cx="256" cy="378" r="5" fill="#F472B6" opacity="0.5"/>
  <circle cx="256" cy="222" r="5" fill="#FFC72C" opacity="0.5"/>

  <!-- Connection lines to center -->
  <line x1="400" y1="140" x2="400" y2="252" stroke="rgba(255,199,44,0.15)" stroke-width="1"/>
  <line x1="544" y1="222" x2="428" y2="272" stroke="rgba(167,139,250,0.15)" stroke-width="1"/>
  <line x1="544" y1="378" x2="428" y2="328" stroke="rgba(96,165,250,0.15)" stroke-width="1"/>
  <line x1="400" y1="460" x2="400" y2="348" stroke="rgba(52,211,153,0.15)" stroke-width="1"/>
  <line x1="256" y1="378" x2="372" y2="328" stroke="rgba(244,114,182,0.15)" stroke-width="1"/>
  <line x1="256" y1="222" x2="372" y2="272" stroke="rgba(255,199,44,0.15)" stroke-width="1"/>

  <!-- Placeholder label -->
  <rect x="260" y="268" width="280" height="64" rx="8" fill="rgba(255,255,255,0.03)" stroke="rgba(255,255,255,0.08)" stroke-width="1"/>
  <text x="400" y="293" font-family="Outfit, Arial, sans-serif" font-size="11" font-weight="700" fill="rgba(255,255,255,0.25)" text-anchor="middle" letter-spacing="0.15em">PLACEHOLDER</text>
  <text x="400" y="316" font-family="Outfit, Arial, sans-serif" font-size="13" font-weight="600" fill="rgba(255,255,255,0.15)" text-anchor="middle">vision-placeholder.svg</text>
</svg>
